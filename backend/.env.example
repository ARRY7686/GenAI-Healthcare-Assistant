# Copy to .env and edit. All vars are prefixed TRIAGE_.

# Provider: mock (default, offline, no secrets) | gemini (real LLM — Google Gemini)
TRIAGE_LLM_PROVIDER=mock

# To use Google Gemini: set the provider above to "gemini", run
#   pip install google-generativeai
# and provide your key below. Default model: gemini-2.0-flash (override with TRIAGE_GEMINI_MODEL).
# TRIAGE_GEMINI_API_KEY=
# TRIAGE_GEMINI_MODEL=gemini-2.0-flash

# Adaptive questioning (feature #2)
TRIAGE_MAX_CLARIFYING_TURNS=6
TRIAGE_PROMPT_VERSION=v1

# CORS — the Vite frontend dev server
TRIAGE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
